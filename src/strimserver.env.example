FFMPEG_LOG_LEVEL="info"
STRIMSERVER_SRT_PORT=9000

# SRT config
SRT_PACKET_SIZE=1316
SRT_LATENCY_US=80000

# MAX_BW_BYTES == 0 -> relative mode (calculated by OVERHEAD_BW_PERCENT)
SRT_MAX_BW_BYTES_PER_SEC=0

# convert to BYTES_PER_SEC -> sender BW (bps) / 8
SRT_INPUT_BW_BYTES_PER_SEC=9000000
SRT_OVERHEAD_BW_PERCENT=25


NORMALIZED_VIDEO_BITRATE="9000k"
NORMALIZED_VIDEO_MAXRATE="9000k"
NORMALIZED_VIDEO_MINRATE="9000k"
NORMALIZED_VIDEO_BUFSIZE="9000k"
NORMALIZED_AUDIO_BITRATE="320k"
SCALED_VIDEO_BITRATE="9000k"
SCALED_VIDEO_MAXRATE="9000k"
SCALED_VIDEO_MINRATE="9000k"
SCALED_VIDEO_BUFSIZE="9000k"
TWITCH_INGEST_SERVER=live.twitch.tv
TWITCH_STREAM_KEY=blahblah
EGRESS_VIDEO_BITRATE="2500k"
EGRESS_VIDEO_MAXRATE="2500k"
EGRESS_VIDEO_MINRATE="2500k"
EGRESS_VIDEO_BUFSIZE="2500k"
EGRESS_AUDIO_BITRATE="160k"
BANDWIDTH_TEST=false
